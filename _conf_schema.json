{
    "Whitelist": {
        "type": "object",
        "description": "白名单配置",
        "items": {
            "WhitelistGroups": {
                "type": "list",
                "description": "白名单群聊列表",
                "hint": "指定本插件在哪些群聊中工作，若留空则默认在所有群聊中启用。",
                "default": [
                    "114514"
                ]
            },
            "AllowTemporaryConversationFromAllowedGroup": {
                "type": "bool",
                "description": "处理来自白名单群聊中的临时会话消息",
                "hint": "是否允许来自白名单群聊的用户创建的临时会话中使用本插件。",
                "default": false
            },
            "WhitelistFriends": {
                "type": "list",
                "description": "白名单好友列表",
                "hint": "指定本插件在哪些私聊中工作，若留空则默认在所有私聊中启用。",
                "default": [
                    "114514"
                ]
            }
        }
    },
    "GlobalEnable": {
        "type": "bool",
        "description": "插件全局开关",
        "hint": "是否启用插件，关闭后插件将不会进行任何操作也不会响应任何事件。此项默认关闭以防止插件安装后被自动启动。建议在配置完所有模块后再打开。",
        "default": false
    },
    "CoreConfig": {
        "type": "object",
        "description": "核心功能配置",
        "items": {
            "BanSystem": {
                "type": "object",
                "description": "封禁系统配置",
                "items": {
                    "Banlist": {
                        "type": "template_list",
                        "description": "封禁列表",
                        "templates": {
                            "SingleBan": {
                                "name": "单一封禁",
                                "hint": "封禁单个用户。",
                                "display_item": "User",
                                "hide_hint_in_list": true,
                                "items": {
                                    "User": {
                                        "type": "string",
                                        "description": "封禁目标",
                                        "hint": "要封禁的目标账号 ID。"
                                    },
                                    "Reason": {
                                        "type": "string",
                                        "description": "封禁原因",
                                        "hint": "可选，用于记录封禁原因以防被忘了。"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "ModuleConfig": {
        "type": "object",
        "description": "模块配置",
        "items": {
            "GroupRequestReview": {
                "type": "object",
                "description": "加群请求审核",
                "items": {
                    "Enable": {
                        "type": "bool",
                        "description": "模块开关",
                        "default": false
                    },
                    "ReviewStrategy": {
                        "type": "template_list",
                        "description": "群聊审核策略配置",
                        "templates": {
                            "Dedicated": {
                                "name": "专用策略",
                                "hint": "指定特定群聊的审核策略，仅对该群聊生效，每个群聊应当仅配置一个专用策略。",
                                "display_item": "TargetGroup",
                                "hide_hint_in_list": true,
                                "items": {
                                    "TargetGroup": {
                                        "type": "string",
                                        "description": "策略适用群聊",
                                        "hint": "要应用此策略群聊的群号，每个专用策略仅支持应用一个群聊。"
                                    },
                                    "UseBanlist": {
                                        "type": "bool",
                                        "description": "拒绝被封禁账号",
                                        "hint": "直接拒绝处于封禁列表中账号的加群请求。",
                                        "default": true
                                    },
                                    "TimeLimit": {
                                        "type": "object",
                                        "description": "加群频率限制",
                                        "hint": "统计最近单位时间内的加群请求次数，若该段时间内请求次数达到上限将拒绝其请求。",
                                        "items": {
                                            "Enable": {
                                                "type": "bool",
                                                "description": "是否启用加群频率限制",
                                                "default": true
                                            },
                                            "StatisticalTime": {
                                                "type": "int",
                                                "description": "统计时间",
                                                "hint": "单位为分钟。",
                                                "default": 10,
                                                "slider": {
                                                    "min": 1,
                                                    "max": 60,
                                                    "step": 1
                                                }
                                            },
                                            "TotalAttempt": {
                                                "type": "int",
                                                "description": "单位时间内加群次数上限",
                                                "hint": "加群者于单位时间内最多可以尝试加群多少次。",
                                                "default": 3,
                                                "slider": {
                                                    "min": 1,
                                                    "max": 10,
                                                    "step": 1
                                                }
                                            }
                                        }
                                    },
                                    "LevelLimit": {
                                        "type": "object",
                                        "description": "等级限制配置",
                                        "items": {
                                            "MinLevel": {
                                                "type": "int",
                                                "description": "最低等级限制",
                                                "hint": "设定加群者的 QQ 等级至少要高于多少级，设为0以禁用该功能。",
                                                "default": 0,
                                                "slider": {
                                                    "min": 0,
                                                    "max": 64,
                                                    "step": 1
                                                }
                                            },
                                            "SkipInvalidLevel": {
                                                "type": "bool",
                                                "description": "获取等级失败时跳过校验",
                                                "hint": "如果获取等级失败（例如目标在资料卡中隐藏了等级）则跳过校验，若禁用此项则将拒绝其加群请求。",
                                                "default": false
                                            }
                                        }
                                    },
                                    "Regex": {
                                        "type": "string",
                                        "description": "正则表达式",
                                        "hint": "用于校验加群者填写答案的正则表达式，若校验通过将放行，反之拒绝。",
                                        "default": ".*"
                                    }
                                }
                            },
                            "Common": {
                                "name": "通用策略",
                                "hint": "所有未配置专用策略的群聊均将使用该策略，该策略应当仅添加一个。",
                                "items": {
                                    "UseBanlist": {
                                        "type": "bool",
                                        "description": "拒绝被封禁账号",
                                        "hint": "直接拒绝处于封禁列表中账号的加群请求。",
                                        "default": true
                                    },
                                    "TimeLimit": {
                                        "type": "object",
                                        "description": "加群频率限制",
                                        "hint": "限制加群者短时间内的加群次数。",
                                        "items": {
                                            "Enable": {
                                                "type": "bool",
                                                "description": "是否启用加群频率限制",
                                                "default": true
                                            },
                                            "StatisticalTime": {
                                                "type": "int",
                                                "description": "统计时间",
                                                "hint": "统计最近配置的分钟数内的加群次数。",
                                                "default": 10,
                                                "slider": {
                                                    "min": 1,
                                                    "max": 60,
                                                    "step": 1
                                                }
                                            },
                                            "TotalAttempt": {
                                                "type": "int",
                                                "description": "配置时间内加群次数上限",
                                                "hint": "加群者于配置时间内最多可以尝试加群多少次，超出将触发速率限制。",
                                                "default": 3,
                                                "slider": {
                                                    "min": 1,
                                                    "max": 10,
                                                    "step": 1
                                                }
                                            },
                                            "PunishmentDuration": {
                                                "type": "int",
                                                "description": "频率限制时长",
                                                "hint": "加群者触发速率限制后要限制其加群的时长，单位为分钟，期间内该加群者的加群请求将被直接拒绝。",
                                                "default": 10,
                                                "slider": {
                                                    "min": 1,
                                                    "max": 60,
                                                    "step": 1
                                                }
                                            }
                                        }
                                    },
                                    "LevelLimit": {
                                        "type": "object",
                                        "description": "等级限制配置",
                                        "items": {
                                            "MinLevel": {
                                                "type": "int",
                                                "description": "最低等级限制",
                                                "hint": "设定加群者的 QQ 等级至少要高于多少级，设为0以禁用该功能。",
                                                "default": 0,
                                                "slider": {
                                                    "min": 0,
                                                    "max": 64,
                                                    "step": 1
                                                }
                                            },
                                            "SkipInvalidLevel": {
                                                "type": "bool",
                                                "description": "获取等级失败时跳过校验",
                                                "hint": "如果获取等级失败（例如目标在资料卡中隐藏了等级）则跳过校验，若禁用此项则将拒绝其加群请求。",
                                                "default": false
                                            }
                                        }
                                    },
                                    "Regex": {
                                        "type": "string",
                                        "description": "正则表达式",
                                        "hint": "用于校验加群者填写答案的正则表达式，若校验通过将放行，反之拒绝。",
                                        "default": ".*"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "EnableSendLike": {
                "type": "bool",
                "description": "启用赞我模块",
                "default": false
            }
        }
    },
    "MessageTemplate": {
        "type": "object",
        "description": "消息模板配置",
        "items": {
            "General": {
                "type": "object",
                "description": "通用消息",
                "items": {
                    "UnknownError": {
                        "type": "string",
                        "description": "发生未知错误时的提示消息",
                        "default": "发生未知错误，请重试。"
                    }
                }
            },
            "BanSystem": {
                "type": "object",
                "description": "封禁系统",
                "items": {
                    "AddNewBan": {
                        "type": "string",
                        "description": "添加新封禁用户成功时发送的消息",
                        "hint": "可用占位符有 {user_id}（用户 ID）。",
                        "default": "封禁用户 {user_id} 成功。"
                    },
                    "DuplicateBan": {
                        "type": "string",
                        "description": "添加已存在封禁用户时发送的消息",
                        "hint": "可用占位符有 {user_id}（用户 ID）。",
                        "default": "用户 {user_id} 已被封禁，无需重复添加。"
                    },
                    "RemoveBan": {
                        "type": "string",
                        "description": "移除封禁用户成功时发送的消息",
                        "hint": "可用占位符有 {user_id}（用户 ID）。",
                        "default": "移除封禁用户 {user_id} 成功。"
                    },
                    "ListBan": {
                        "type": "string",
                        "description": "列出封禁用户列表时发送的消息",
                        "hint": "可用占位符有 {banlist}（封禁用户列表）。",
                        "default": "当前封禁用户列表：{banlist}"
                    },
                    "BanlistFormat": {
                        "type": "string",
                        "description": "每行封禁用户列表的显示格式",
                        "hint": "可用占位符有 {user_id}（用户 ID）, {reason}（封禁原因）。",
                        "default": "\n- 用户 ID：{user_id}，封禁理由：{reason}。"
                    },
                    "BanlistEmpty": {
                        "type": "string",
                        "description": "当没有任何人被封禁时发送的消息",
                        "default": "当前封禁列表为空。"
                    }
                }
            },
            "EconomicSystem": {
                "type": "object",
                "description": "经济系统",
                "items": {
                    "CurrencyName": {
                        "type": "string",
                        "description": "货币名称",
                        "default": "币"
                    },
                    "SelfAccountNotFound": {
                        "type": "string",
                        "description": "自身账户不存在时发送的消息",
                        "default": "未找到你的银行账户，请先注册。"
                    },
                    "TargetAccountNotFound": {
                        "type": "string",
                        "description": "目标账户不存在时发送的消息",
                        "default": "找不到目标的银行账户，请检查目标是否已进行注册。"
                    },
                    "InvalidAmount": {
                        "type": "string",
                        "description": "无效金额时发送的消息",
                        "default": "金额无效。"
                    },
                    "SignUpSuccess": {
                        "type": "string",
                        "description": "注册成功时发送的消息",
                        "default": "注册成功！"
                    },
                    "DuplicateAccount": {
                        "type": "string",
                        "description": "重复注册时发送的消息",
                        "default": "你已经注册过账户了。"
                    },
                    "RejectCancelByBalance": {
                        "type": "string",
                        "description": "因账户内有余额而注销失败时发送的消息",
                        "hint": "可用占位符有 {balance}（余额），{currency_name}（货币名称）。",
                        "default": "你的账户内仍剩余 {balance} {currency_name}，无法注销账户。"
                    },
                    "CancelSuccess": {
                        "type": "string",
                        "description": "注销成功时发送的消息",
                        "default": "注销成功。"
                    },
                    "AccountBalance": {
                        "type": "string",
                        "description": "查询余额时发送的消息",
                        "hint": "可用占位符有 {balance}（余额），{currency_name}（货币名称）。",
                        "default": "你的银行账户余额为 {balance} {currency_name}。"
                    },
                    "TransferSuccess": {
                        "type": "string",
                        "description": "转账成功时发送的消息",
                        "hint": "可用占位符有 {target_id}（目标用户 ID），{amount}（转账金额），{currency_name}（货币名称）。",
                        "default": "转账成功！已向 {target_id} 转账 {amount} {currency_name}。"
                    },
                    "InvalidTransferAmount": {
                        "type": "string",
                        "description": "无效转账金额时发送的消息",
                        "default": "转账金额无效。"
                    },
                    "DeductionSuccess": {
                        "type": "string",
                        "description": "扣款成功时发送的消息",
                        "hint": "可用占位符有 {target_id}（目标用户 ID），{amount}（扣款金额），{currency_name}（货币名称）。",
                        "default": "已从 {target_id} 扣款 {amount} {currency_name}。"
                    },
                    "DepositSuccess": {
                        "type": "string",
                        "description": "入款成功时发送的消息",
                        "hint": "可用占位符有 {target_id}（目标用户 ID），{amount}（入款金额）。",
                        "default": "已向 {target_id} 的银行账户增加 {amount} {currency_name}。"
                    }
                }
            },
            "GroupRequestReview": {
                "type": "object",
                "description": "加群请求审核",
                "hint": "QQ 会限制拒绝理由的最大字数（然而我不清楚具体是多少），超出会被截断，建议拒绝理由稍微简洁一些。",
                "items": {
                    "RejectByBanned": {
                        "type": "string",
                        "description": "封禁账号拒绝时使用的理由",
                        "hint": "当加群者处于封禁列表中时，将使用此理由拒绝其加群请求。",
                        "default": "您已被封禁，无法加入群聊。"
                    },
                    "RejectByRateLimit": {
                        "type": "string",
                        "description": "速率限制拒绝时使用的理由",
                        "hint": "当加群者触发速率限制时，将使用此理由拒绝其加群请求。可用占位符有 {remaining_time}（频率限制剩余时间，单位为分钟，向上取整）。",
                        "default": "您的加群请求过于频繁，请在 {remaining_time} 分钟后重试。"
                    },
                    "RejectByInvalidLevel": {
                        "type": "string",
                        "description": "无效等级拒绝时使用的理由",
                        "hint": "当获取加群者等级失败且未选择跳过校验时，将使用此理由拒绝其加群请求。",
                        "default": "获取你的 QQ 等级失败，请在设置内对外展示你的等级。"
                    },
                    "RejectByLevelLimit": {
                        "type": "string",
                        "description": "等级限制拒绝时使用的理由",
                        "hint": "当加群者触发等级限制时，将使用此理由拒绝其加群请求。可用占位符有 {required_level}（最低限制等级）。",
                        "default": "您的等级低于 {required_level}，无法加入群聊。"
                    },
                    "RejectByRegex": {
                        "type": "string",
                        "description": "正则表达式拒绝时使用的理由",
                        "hint": "当加群者填写答案未匹配正则表达式时，将使用此理由拒绝其加群请求。",
                        "default": "您的答案不符合要求，请重新填写。"
                    }
                }
            },
            "SendLike": {
                "type": "object",
                "description": "赞我",
                "items": {
                    "SendSuccess": {
                        "type": "string",
                        "description": "点赞成功时发送的消息",
                        "hint": "可用占位符有 {times}（尝试点赞次数，协议端限制不支持查看实际点赞次数）。",
                        "default": "点赞 {times} 次成功！"
                    },
                    "InvalidTimes": {
                        "type": "string",
                        "description": "无效点赞次数时发送的消息",
                        "default": "无效的点赞次数，范围需在 1-20 之间。"
                    },
                    "DailyLimit": {
                        "type": "string",
                        "description": "点赞次数达每日上限时发送的消息",
                        "default": "点赞次数已达今日上限。"
                    }
                }
            }
        }
    }
}