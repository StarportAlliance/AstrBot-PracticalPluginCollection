{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://astrbot.app/schemas/plugin-conf-schema.json",
    "title": "AstrBot Plugin Configuration Schema",
    "description": "用于验证插件 _conf_schema.json 的 JSON Schema。（此配置由 DeepSeek v4 Pro 基于文档生成）",
    "type": "object",
    "additionalProperties": {
        "$ref": "#/$defs/configItem"
    },
    "$defs": {
        "configItem": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "description": "配置项类型（必填）",
                    "enum": [
                        "string",
                        "text",
                        "int",
                        "float",
                        "bool",
                        "object",
                        "list",
                        "dict",
                        "template_list",
                        "file"
                    ]
                },
                "description": {
                    "description": "配置项的描述",
                    "type": "string"
                },
                "hint": {
                    "description": "配置项的提示信息，悬浮在问号按钮上显示",
                    "type": "string"
                },
                "obvious_hint": {
                    "description": "hint 是否醒目显示",
                    "type": "boolean",
                    "default": false
                },
                "default": {
                    "description": "配置项的默认值，类型取决于 type 字段"
                },
                "invisible": {
                    "description": "是否在管理面板中隐藏",
                    "type": "boolean",
                    "default": false
                },
                "options": {
                    "description": "下拉列表可选项",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "labels": {
                    "description": "下拉选项的国际化标签，与 options 一一对应",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "editor_mode": {
                    "description": "是否启用代码编辑器模式（v3.5.10+）",
                    "type": "boolean",
                    "default": false
                },
                "editor_language": {
                    "description": "代码编辑器的语言模式",
                    "type": "string",
                    "default": "json"
                },
                "editor_theme": {
                    "description": "代码编辑器主题",
                    "enum": [
                        "vs-light",
                        "vs-dark"
                    ],
                    "default": "vs-light"
                },
                "_special": {
                    "description": "调用 AstrBot 内置的可视化选取功能（v4.0.0+）",
                    "type": "string"
                },
                "items": {
                    "description": "当 type 为 object 时的子 Schema；当 type 为 list 时指定元素类型",
                    "anyOf": [
                        {
                            "$ref": "#/$defs/objectItems"
                        },
                        {
                            "$ref": "#/$defs/listItems"
                        }
                    ]
                },
                "file_types": {
                    "description": "file 类型允许上传的文件扩展名列表",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "templates": {
                    "description": "template_list 类型的模板定义（必填）",
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/templateDefinition"
                    }
                },
                "template_schema": {
                    "description": "dict 类型的快捷编辑模板",
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/templateSchemaItem"
                    }
                },
                "slider": {
                    "description": "滑块控件配置（用于 int/float 类型）",
                    "$ref": "#/$defs/sliderConfig"
                },
                "name": {
                    "description": "配置项的显示名称（用于 template_schema 或模板 items）",
                    "type": "string"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "object"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "items"
                        ],
                        "properties": {
                            "items": {
                                "$ref": "#/$defs/objectItems"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "template_list"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "templates"
                        ]
                    }
                }
            ]
        },
        "objectItems": {
            "description": "object 类型的子配置项定义",
            "type": "object",
            "additionalProperties": {
                "$ref": "#/$defs/configItem"
            }
        },
        "listItems": {
            "description": "list 类型的元素类型定义",
            "type": "object",
            "properties": {
                "type": {
                    "description": "列表元素类型",
                    "enum": [
                        "string",
                        "text",
                        "int",
                        "float",
                        "bool"
                    ]
                }
            },
            "required": [
                "type"
            ]
        },
        "templateDefinition": {
            "description": "template_list 中单个模板的定义",
            "type": "object",
            "required": [
                "name",
                "items"
            ],
            "properties": {
                "name": {
                    "description": "模板显示名称",
                    "type": "string"
                },
                "hint": {
                    "description": "模板提示信息",
                    "type": "string"
                },
                "display_item": {
                    "description": "在折叠列表中显示的字段 key（支持点号路径）",
                    "type": "string"
                },
                "hide_hint_in_list": {
                    "description": "在折叠列表中隐藏模板 hint",
                    "type": "boolean",
                    "default": false
                },
                "items": {
                    "description": "模板内的配置项",
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/configItem"
                    }
                }
            }
        },
        "templateSchemaItem": {
            "description": "dict template_schema 中的单个条目",
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "name": {
                    "description": "显示名称",
                    "type": "string"
                },
                "description": {
                    "description": "描述",
                    "type": "string"
                },
                "hint": {
                    "description": "提示信息",
                    "type": "string"
                },
                "type": {
                    "description": "类型",
                    "enum": [
                        "string",
                        "text",
                        "int",
                        "float",
                        "bool"
                    ]
                },
                "default": {
                    "description": "默认值"
                },
                "slider": {
                    "description": "滑块控件配置",
                    "$ref": "#/$defs/sliderConfig"
                }
            }
        },
        "sliderConfig": {
            "description": "滑块控件参数",
            "type": "object",
            "required": [
                "min",
                "max"
            ],
            "properties": {
                "min": {
                    "description": "最小值",
                    "type": "number"
                },
                "max": {
                    "description": "最大值",
                    "type": "number"
                },
                "step": {
                    "description": "步长",
                    "type": "number"
                }
            }
        }
    }
}